CompileFlags:
  QueryDriver: [ "C:/msys64/ucrt64/bin/g++.exe" ]
  Compiler: C:/msys64/ucrt64/bin/g++.exe
---
If:
  PathMatch: third_party/glad/include/glad/.*

CompileFlags:
  Remove: [-I*, -isystem*]
Diagnostics:
  Suppress: ["*"]

---
If:
  PathMatch: src/.*

CompileFlags:
  Add: [
    -DGL_GLEXT_PROTOTYPES,
    
    # -D__glad_h_,
    # -target, x86_64-w64-mingw32,
    # -isystem, C:/msys64/ucrt64/include,
    # -isystem, C:/msys64/ucrt64/include/c++,
    -isystem, C:/msys64/ucrt64/include/c++/16.1.0, 
    -isystem, C:/msys64/ucrt64/include/c++/16.1.0/x86_64-w64-mingw32,
    # -isystem, C:/msys64/ucrt64/lib/gcc/x86_64-w64-mingw32/16.1.0/include,
    # -isystem, C:/msys64/ucrt64/lib/gcc/x86_64-w64-mingw32/16.1.0/include-fixed,
    -include, GL/gl.h,
    -include, GL/glext.h,
          -finput-charset=utf-8,
      -fexec-charset=utf-8
  ]
  Remove: [
    -include*glad\.h
  ]
Diagnostics:
  Suppress: [ pp_hash_error, expected_unqualified_id]
Compiler: C:/msys64/ucrt64/bin/g++.exe
